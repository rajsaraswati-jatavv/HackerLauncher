<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NETWORK SPEED MONITOR"
            android:textColor="#00FF00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <!-- Download & Upload Speed Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/textViewDownloadSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↓ 0 KB/s"
                android:textColor="#00FF00"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/textViewUploadSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↑ 0 KB/s"
                android:textColor="#4488FF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Speed Graph View -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginBottom="8dp">

            <view
                class="com.hackerlauncher.modules.NetworkSpeedMonitorFragment$SpeedGraphView"
                android:id="@+id/speedGraphView"
                android:layout_width="match_parent"
                android:layout_height="150dp" />
        </FrameLayout>

        <!-- Total Download & Upload Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/textViewTotalDown"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total ↓: 0"
                android:textColor="#00FF00"
                android:textSize="14sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/textViewTotalUp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total ↑: 0"
                android:textColor="#4488FF"
                android:textSize="14sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Network Type -->
        <TextView
            android:id="@+id/textViewNetworkType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type: --"
            android:textColor="#FFFF00"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- IP Address -->
        <TextView
            android:id="@+id/textViewIpAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IP: --"
            android:textColor="#888888"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- DNS -->
        <TextView
            android:id="@+id/textViewDns"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DNS: --"
            android:textColor="#888888"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- Gateway -->
        <TextView
            android:id="@+id/textViewGateway"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gateway: --"
            android:textColor="#888888"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- Connection Quality -->
        <TextView
            android:id="@+id/textViewConnectionQuality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quality: --"
            android:textColor="#00FF00"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- Latency -->
        <TextView
            android:id="@+id/textViewLatency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Latency: -- ms"
            android:textColor="#FFFF00"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <!-- Speed Test Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSpeedTest"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Run Speed Test"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="12sp"
            app:backgroundTint="#1B3A1B"
            app:strokeColor="#00FF00"
            android:layout_marginBottom="8dp" />

        <!-- Speed Test Progress -->
        <ProgressBar
            android:id="@+id/progressBarSpeedTest"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#00FF00"
            android:progressBackgroundTint="#1A1A1A"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- Connections Recycler -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewConnections"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#0A0A0A"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
