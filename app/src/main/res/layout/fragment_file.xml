<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etFilePath"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="/sdcard"
            android:textColorHint="#005500"
            android:textColor="#00FF00"
            android:background="#0A1A0A"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:padding="8dp"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnBrowse"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="BROWSE"
            android:textColor="#000000"
            android:backgroundTint="#00FF00"
            android:fontFamily="monospace"
            android:textSize="11sp" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btnViewFile" android:text="View" style="@style/HackerButtonSmall" />
            <Button android:id="@+id/btnEncrypt" android:text="Encrypt" style="@style/HackerButtonSmall" />
            <Button android:id="@+id/btnDecrypt" android:text="Decrypt" style="@style/HackerButtonSmall" />
            <Button android:id="@+id/btnSecureDelete" android:text="Secure Del" style="@style/HackerButtonSmall" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFiles"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp" />

    <ScrollView
        android:id="@+id/scrollViewFile"
        android:layout_width="match_parent"
        android:layout_height="100dp">

        <TextView
            android:id="@+id/tvFileOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="10sp" />
    </ScrollView>
</LinearLayout>
