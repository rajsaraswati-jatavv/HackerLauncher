<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- URL Input + Download Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="#0A0A0A">

        <EditText
            android:id="@+id/editDownloadUrl"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Enter URL..."
            android:textColorHint="#006600"
            android:textColor="#00FF00"
            android:background="#0A1A0A"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:inputType="textUri"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnDownload"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="GET"
            android:textColor="#000000"
            android:backgroundTint="#00FF00"
            android:fontFamily="monospace"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#0A0A0A">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <Button
                android:id="@+id/tabAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="ALL"
                android:textColor="#000000"
                android:backgroundTint="#00FF00"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:minWidth="64dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/tabImages"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="IMAGES"
                android:textColor="#00FF00"
                android:backgroundTint="#1A1A1A"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:minWidth="64dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/tabVideos"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="VIDEOS"
                android:textColor="#00FF00"
                android:backgroundTint="#1A1A1A"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:minWidth="64dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/tabDocs"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="DOCS"
                android:textColor="#00FF00"
                android:backgroundTint="#1A1A1A"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:minWidth="64dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/tabApks"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="APKs"
                android:textColor="#00FF00"
                android:backgroundTint="#1A1A1A"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:minWidth="64dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Active Downloads List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDownloads"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

</LinearLayout>
