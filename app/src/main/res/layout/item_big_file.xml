<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical"
    android:background="#0A0A0A">

    <CheckBox
        android:id="@+id/cbBigFileSelect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="#00FF00" />

    <ImageView
        android:id="@+id/ivFileTypeIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="8dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/tvBigFileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#00FF00"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:ellipsize="middle" />

        <TextView
            android:id="@+id/tvBigFilePath"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:ellipsize="start" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvBigFileSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFF00"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvBigFileType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/tvBigFileDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#666666"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
