<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#0A0A0A">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AI Chat"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnClearChat"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="CLEAR"
            android:textColor="#00FF00"
            android:backgroundTint="#1A1A1A"
            android:fontFamily="monospace"
            android:textSize="10sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <TextView
        android:id="@+id/tvTypingIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI is typing..."
        android:textColor="#00AA00"
        android:fontFamily="monospace"
        android:textSize="11sp"
        android:paddingStart="12dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#0A0A0A">

        <EditText
            android:id="@+id/etChatMessage"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Type a message..."
            android:textColorHint="#005500"
            android:textColor="#00FF00"
            android:background="#0A1A0A"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:padding="8dp"
            android:singleLine="true"
            android:imeOptions="actionSend" />

        <Button
            android:id="@+id/btnChatSend"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="SEND"
            android:textColor="#000000"
            android:backgroundTint="#00FF00"
            android:fontFamily="monospace"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
