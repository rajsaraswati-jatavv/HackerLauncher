<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="#0A0A0A">

        <EditText
            android:id="@+id/searchClipboard"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Search clipboard..."
            android:textColorHint="#006600"
            android:textColor="#00FF00"
            android:background="#0A1A0A"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp" />

        <ImageButton
            android:id="@+id/btnSortClipboard"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="#0A1A0A"
            android:layout_marginStart="8dp"
            android:contentDescription="Sort" />
    </LinearLayout>

    <!-- Clipboard Items List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerClipboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Bottom Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center"
        android:background="#0A0A0A">

        <Button
            android:id="@+id/btnClearAll"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="CLEAR ALL"
            android:textColor="#000000"
            android:backgroundTint="#00FF00"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnPinAll"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="PIN ALL"
            android:textColor="#00FF00"
            android:backgroundTint="#1A1A1A"
            android:fontFamily="monospace"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
