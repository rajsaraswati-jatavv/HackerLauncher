<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#000000">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HackerLauncher"
        android:textColor="#00FF00"
        android:textSize="32sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Authenticate to unlock"
        android:textColor="#00AA00"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="48dp" />

    <TextView
        android:id="@+id/tvLoginStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FF4444"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnGoogleLogin"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Sign in with Google"
        android:textColor="#000000"
        android:backgroundTint="#FFFFFF"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnGithubLogin"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Sign in with GitHub"
        android:textColor="#FFFFFF"
        android:backgroundTint="#333333"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A1A"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnSkipLogin"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Continue as Guest"
        android:textColor="#00FF00"
        android:backgroundTint="#0A1A0A"
        android:fontFamily="monospace"
        android:strokeWidth="1dp" />

</LinearLayout>
