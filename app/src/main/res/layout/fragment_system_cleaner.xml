<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Storage Usage Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0A0A0A"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvStorageUsage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Storage: 72% Used"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <ProgressBar
                android:id="@+id/storageProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:max="100"
                android:progress="72"
                android:progressTint="#00FF00"
                android:progressBackgroundTint="#1A1A1A"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvStorageDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="═══ STORAGE INFO ═══\nTotal: 64 GB\nUsed: 46.2 GB\nFree: 17.8 GB"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Scan Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScan"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="SCAN SYSTEM"
            android:textColor="#000000"
            android:backgroundTint="#00FF00"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Scan Progress -->
        <ProgressBar
            android:id="@+id/scanProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#00FF00"
            android:progressBackgroundTint="#1A1A1A"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- Total Size -->
        <TextView
            android:id="@+id/tvTotalSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected: 0 B / Total: 0 B"
            android:textColor="#FFFF00"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <!-- Select All -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/btnSelectAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select All"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:buttonTint="#00FF41"
                android:checked="true" />
        </LinearLayout>

        <!-- Empty State -->
        <TextView
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:text="No junk files found. Tap SCAN to search."
            android:textColor="#444444"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- Results Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="[ SCAN RESULTS ]"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Results Recycler -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/junkRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="12dp" />

        <!-- Clean Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCleanSelected"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Clean Selected (0)"
                android:textColor="#000000"
                android:backgroundTint="#FFFF00"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCleanAll"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="CLEAN ALL"
                android:textColor="#000000"
                android:backgroundTint="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
