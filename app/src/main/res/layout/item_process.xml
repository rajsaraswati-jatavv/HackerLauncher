<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#1A1A1A"
    android:padding="12dp"
    android:layout_marginBottom="4dp"
    android:gravity="center_vertical">

    <!-- Icon -->
    <ImageView
        android:id="@+id/imgProcessIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@android:drawable/ic_menu_manage"
        android:contentDescription="Process Icon"
        android:layout_marginEnd="12dp" />

    <!-- Name + PID + Memory -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtProcessName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="com.app.process"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/txtPid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PID: 1234"
                android:textColor="#006600"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/txtMemory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="42 MB"
                android:textColor="#006600"
                android:fontFamily="monospace"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Kill Button -->
    <Button
        android:id="@+id/btnKill"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="KILL"
        android:textColor="#000000"
        android:backgroundTint="#00FF00"
        android:fontFamily="monospace"
        android:textSize="10sp"
        android:minWidth="56dp"
        android:layout_marginStart="8dp" />

</LinearLayout>
