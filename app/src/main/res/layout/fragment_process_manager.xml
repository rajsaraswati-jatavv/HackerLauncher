<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Search Bar + Sort + Refresh -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0A0A0A"
            android:padding="8dp"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/editTextSearch"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="Search process..."
                android:textColorHint="#006600"
                android:textColor="#00FF00"
                android:background="#0A1A0A"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:singleLine="true" />

            <Spinner
                android:id="@+id/spinnerSort"
                android:layout_width="110dp"
                android:layout_height="36dp"
                android:background="#0A1A0A"
                android:popupBackground="#0A0A0A"
                android:layout_marginStart="6dp" />

            <ImageButton
                android:id="@+id/buttonRefresh"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_rotate"
                android:background="#0A1A0A"
                android:contentDescription="Refresh"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/textViewProcessCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Processes: 0"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/textViewCpuUsage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CPU: 0%"
                android:textColor="#FFFF00"
                android:fontFamily="monospace"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Empty State -->
        <TextView
            android:id="@+id/textViewEmptyState"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:text="No processes found"
            android:textColor="#444444"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Process List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewProcesses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
