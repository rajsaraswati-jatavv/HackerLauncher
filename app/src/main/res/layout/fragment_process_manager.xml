<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Search Bar + Sort -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="#0A0A0A">

        <EditText
            android:id="@+id/searchProcess"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Search process..."
            android:textColorHint="#006600"
            android:textColor="#00FF00"
            android:background="#0A1A0A"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp" />

        <Spinner
            android:id="@+id/spinnerSort"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:background="#0A1A0A"
            android:popupBackground="#0A0A0A"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Process List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerProcesses"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Kill All Button -->
    <Button
        android:id="@+id/btnKillAll"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="KILL ALL PROCESSES"
        android:textColor="#000000"
        android:backgroundTint="#00FF00"
        android:fontFamily="monospace"
        android:textSize="13sp"
        android:layout_margin="12dp" />

</LinearLayout>
