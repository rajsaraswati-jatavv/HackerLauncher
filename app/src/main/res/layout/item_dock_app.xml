<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dockAppContainer"
    android:layout_width="52dp"
    android:layout_height="52dp">

    <!-- App icon -->
    <ImageView
        android:id="@+id/dockAppIconImageView"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center"
        android:contentDescription="Dock app"
        android:src="@drawable/ic_app_default" />

    <!-- Notification badge dot (8dp, top-right corner) -->
    <View
        android:id="@+id/notificationBadgeDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="2dp"
        android:background="#00FF00"
        android:visibility="gone" />

</FrameLayout>
