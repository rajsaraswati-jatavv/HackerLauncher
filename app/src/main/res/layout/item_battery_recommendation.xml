<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="#1A1A2E"
    android:layout_margin="2dp">
    <ImageView android:id="@+id/ivRecIcon" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_info" android:tint="#00FF41"/>
    <TextView android:id="@+id/tvRecommendation" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="14sp" android:fontFamily="monospace" android:layout_marginStart="12dp"/>
</LinearLayout>
