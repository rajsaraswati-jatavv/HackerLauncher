<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center"
    android:background="#1A1A2E"
    android:layout_margin="4dp">
    <TextView android:id="@+id/tvSpeedValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00FF41" android:textSize="36sp" android:fontFamily="monospace" android:textStyle="bold"/>
    <TextView android:id="@+id/tvSpeedUnit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#888888" android:textSize="14sp" android:fontFamily="monospace"/>
</LinearLayout>
