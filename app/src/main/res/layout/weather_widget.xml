<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/weatherWidgetContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0A0A0A"
    android:padding="12dp">

    <!-- Top Row: Weather Icon + Temperature -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Weather Icon Area -->
        <FrameLayout
            android:id="@+id/weatherIconArea"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp">

            <ImageView
                android:id="@+id/weatherIconImageView"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_weather"
                android:contentDescription="Weather condition"
                android:tint="#00FF00" />
        </FrameLayout>

        <!-- Temperature + Condition -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Temperature (large) -->
            <TextView
                android:id="@+id/temperatureTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°C"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="24sp"
                android:textStyle="bold"
                android:shadowColor="#00FF00"
                android:shadowRadius="2" />

            <!-- Condition text -->
            <TextView
                android:id="@+id/conditionTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#009900"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Location -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <ImageView
                android:id="@+id/locationIcon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_location"
                android:contentDescription="Location"
                android:tint="#006600"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/locationTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#006600"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:maxWidth="100dp"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0A1A0A"
        android:layout_marginVertical="8dp" />

    <!-- 3-Day Forecast Row -->
    <LinearLayout
        android:id="@+id/forecastRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Day 1 -->
        <LinearLayout
            android:id="@+id/forecastDay1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/forecastDay1Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mon"
                android:textColor="#009900"
                android:fontFamily="monospace"
                android:textSize="10sp" />

            <ImageView
                android:id="@+id/forecastDay1Icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_weather"
                android:contentDescription="Forecast"
                android:tint="#009900"
                android:layout_marginVertical="2dp" />

            <TextView
                android:id="@+id/forecastDay1Temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Day 2 -->
        <LinearLayout
            android:id="@+id/forecastDay2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/forecastDay2Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tue"
                android:textColor="#009900"
                android:fontFamily="monospace"
                android:textSize="10sp" />

            <ImageView
                android:id="@+id/forecastDay2Icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_weather"
                android:contentDescription="Forecast"
                android:tint="#009900"
                android:layout_marginVertical="2dp" />

            <TextView
                android:id="@+id/forecastDay2Temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Day 3 -->
        <LinearLayout
            android:id="@+id/forecastDay3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/forecastDay3Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wed"
                android:textColor="#009900"
                android:fontFamily="monospace"
                android:textSize="10sp" />

            <ImageView
                android:id="@+id/forecastDay3Icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_weather"
                android:contentDescription="Forecast"
                android:tint="#009900"
                android:layout_marginVertical="2dp" />

            <TextView
                android:id="@+id/forecastDay3Temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Widget label -->
    <TextView
        android:id="@+id/widgetLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HACKER_LAUNCHER"
        android:textColor="#003300"
        android:fontFamily="monospace"
        android:textSize="8sp"
        android:layout_gravity="end"
        android:layout_marginTop="4dp" />

</LinearLayout>
