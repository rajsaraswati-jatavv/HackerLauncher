<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Stats Summary -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0A0A0A"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL"
                android:textColor="#006600"
                android:fontFamily="monospace"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/txtTotalCalls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INCOMING"
                android:textColor="#006600"
                android:fontFamily="monospace"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/txtIncomingCalls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OUTGOING"
                android:textColor="#006600"
                android:fontFamily="monospace"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/txtOutgoingCalls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MISSED"
                android:textColor="#006600"
                android:fontFamily="monospace"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/txtMissedCalls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Filter Tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#0A0A0A">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/tabAllCalls"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="ALL"
                android:textColor="#000000"
                android:backgroundTint="#00FF00"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:minWidth="64dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/tabIncoming"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="IN"
                android:textColor="#00FF00"
                android:backgroundTint="#1A1A1A"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:minWidth="64dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/tabOutgoing"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="OUT"
                android:textColor="#00FF00"
                android:backgroundTint="#1A1A1A"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:minWidth="64dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/tabMissed"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="MISSED"
                android:textColor="#00FF00"
                android:backgroundTint="#1A1A1A"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:minWidth="64dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Call List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCallLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

</LinearLayout>
