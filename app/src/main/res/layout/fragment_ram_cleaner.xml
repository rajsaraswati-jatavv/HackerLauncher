<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- RAM Circular Meter -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <ProgressBar
                android:id="@+id/progressBarRam"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:max="100"
                android:progress="65"
                android:progressTint="#00FF00"
                android:progressBackgroundTint="#1A1A1A" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:gravity="center">

                <TextView
                    android:id="@+id/textViewRamPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="65%"
                    android:textColor="#00FF00"
                    android:fontFamily="monospace"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RAM USED"
                    android:textColor="#006600"
                    android:fontFamily="monospace"
                    android:textSize="10sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- RAM Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/textViewUsedRam"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Used: 4.2 GB"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/textViewTotalRam"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total: 6.0 GB"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/textViewFreeRam"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Free: 1.8 GB"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Visual RAM Meter Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:background="#1A1A1A"
            android:layout_marginBottom="12dp">

            <View
                android:id="@+id/viewRamMeterFill"
                android:layout_width="200dp"
                android:layout_height="match_parent"
                android:background="#00FF00" />
        </LinearLayout>

        <!-- Boost Score -->
        <TextView
            android:id="@+id/textViewBoostScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Boost Score: 35% [FAIR]"
            android:textColor="#FFFF00"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Clean Button -->
        <Button
            android:id="@+id/buttonClean"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="CLEAN NOW"
            android:textColor="#000000"
            android:backgroundTint="#00FF00"
            android:fontFamily="monospace"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Auto-Clean Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0A0A0A"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/textViewAutoCleanStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auto-clean: OFF"
                android:textColor="#888888"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/buttonToggleAutoClean"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Enable Auto-Clean"
                android:textColor="#00FF00"
                android:backgroundTint="#1A1A1A"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:strokeColor="#00FF00" />
        </LinearLayout>

        <!-- Process Count -->
        <TextView
            android:id="@+id/textViewProcessCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Processes: 0"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Process List Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="[ RUNNING PROCESSES ]"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewProcesses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
