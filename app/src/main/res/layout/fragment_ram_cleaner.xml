<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- RAM Meter (Circular Placeholder) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <ProgressBar
                android:id="@+id/progressRamCircular"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:max="100"
                android:progress="65"
                android:progressTint="#00FF00"
                android:progressBackgroundTint="#1A1A1A" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtRamPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="65%"
                    android:textColor="#00FF00"
                    android:fontFamily="monospace"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RAM USED"
                    android:textColor="#006600"
                    android:fontFamily="monospace"
                    android:textSize="10sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- RAM Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/txtRamUsed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Used: 4.2 GB"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/txtRamTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total: 6.0 GB"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/txtRamFree"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Free: 1.8 GB"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Boost Button -->
        <Button
            android:id="@+id/btnBoost"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="⚡ BOOST RAM"
            android:textColor="#000000"
            android:backgroundTint="#00FF00"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Auto-Clean Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Auto-Clean"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="13sp" />

            <Switch
                android:id="@+id/switchAutoClean"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:trackTint="#0A1A0A"
                android:thumbTint="#00FF00" />
        </LinearLayout>

        <!-- Process List -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="[ RUNNING PROCESSES ]"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerRamProcesses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
