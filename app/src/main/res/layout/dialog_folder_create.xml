<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/folderCreateDialogContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0A0A0A"
    android:padding="16dp">

    <!-- Dialog Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=">> CREATE_FOLDER"
        android:textColor="#00FF00"
        android:fontFamily="monospace"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- Folder Name EditText -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FOLDER_NAME"
        android:textColor="#009900"
        android:fontFamily="monospace"
        android:textSize="11sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/folderNameEditText"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#0A1A0A"
        android:hint="Enter folder name..."
        android:textColorHint="#006600"
        android:textColor="#00FF00"
        android:fontFamily="monospace"
        android:textSize="14sp"
        android:paddingStart="10dp"
        android:paddingEnd="8dp"
        android:singleLine="true"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <!-- App Selection Label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SELECT_APPS"
            android:textColor="#009900"
            android:fontFamily="monospace"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/selectedAppCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 selected"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- App Selection RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/appSelectionRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#0A1A0A"
        android:padding="4dp"
        android:scrollbars="vertical"
        android:layout_marginBottom="16dp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/cancelButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="CANCEL"
            android:textColor="#009900"
            android:background="#0A1A0A"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/createButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="CREATE"
            android:textColor="#000000"
            android:background="#00FF00"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
