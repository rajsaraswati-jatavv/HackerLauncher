<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="#1A1A2E"
    android:layout_margin="2dp">
    <CheckBox android:id="@+id/cbTodoCompleted" android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="#00FF41"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
        <TextView android:id="@+id/tvTodoTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#00FF41" android:textSize="14sp" android:fontFamily="monospace"/>
        <TextView android:id="@+id/tvTodoPriority" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#888888" android:textSize="12sp" android:fontFamily="monospace"/>
    </LinearLayout>
    <ImageButton android:id="@+id/btnDeleteTodo" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_delete" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#FF4444"/>
</LinearLayout>
