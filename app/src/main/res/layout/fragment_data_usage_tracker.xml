<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DATA USAGE TRACKER"
            android:textColor="#00FF00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <!-- Mobile & WiFi Data Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/textViewMobileData"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mobile: 0 MB"
                android:textColor="#FF8800"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/textViewWifiData"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WiFi: 0 MB"
                android:textColor="#4488FF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Total Data -->
        <TextView
            android:id="@+id/textViewTotalData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total: 0 MB"
            android:textColor="#00FF00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <!-- Usage Bar Graph View -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="12dp">

            <view
                class="com.hackerlauncher.modules.DataUsageTrackerFragment$UsageBarGraphView"
                android:id="@+id/usageGraphView"
                android:layout_width="match_parent"
                android:layout_height="180dp" />
        </FrameLayout>

        <!-- Period Spinner -->
        <Spinner
            android:id="@+id/spinnerPeriod"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="#111111"
            android:popupBackground="#111111"
            android:layout_marginBottom="8dp" />

        <!-- Period Usage -->
        <TextView
            android:id="@+id/textViewPeriodUsage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Period: 0 MB"
            android:textColor="#FFFF00"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- Alert Threshold -->
        <TextView
            android:id="@+id/textViewAlertThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alert: OFF"
            android:textColor="#888888"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <!-- Alert & Reset Controls Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/editTextAlertThreshold"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="MB"
                android:inputType="number"
                android:textColor="#00FF00"
                android:textColorHint="#555555"
                android:background="#111111"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSetAlert"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Set Alert"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp"
                app:backgroundTint="#1B3A1B"
                app:strokeColor="#00FF00"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonResetCounters"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Reset"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp"
                app:backgroundTint="#1B3A1B"
                app:strokeColor="#00FF00" />
        </LinearLayout>

        <!-- App Usage Recycler -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewAppUsage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#0A0A0A"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
