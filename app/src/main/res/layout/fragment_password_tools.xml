<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Spinner
            android:id="@+id/spinnerPasswordOp"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="#1A1A1A" />

        <Button
            android:id="@+id/btnPasswordGo"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="GO"
            android:textColor="#000000"
            android:backgroundTint="#00FF00"
            android:fontFamily="monospace"
            android:textSize="11sp" />
    </LinearLayout>

    <EditText
        android:id="@+id/etPasswordInput"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:hint="Input (password / hash / text)"
        android:textColorHint="#005500"
        android:textColor="#00FF00"
        android:background="#0A1A0A"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:padding="8dp"
        android:singleLine="true"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Length: "
            android:textColor="#00AA00"
            android:fontFamily="monospace"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/seekBarPasswordLength"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="64"
            android:progress="16" />

        <TextView
            android:id="@+id/tvPasswordLength"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="16"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="12sp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollViewPassword"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tvPasswordOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="11sp" />
    </ScrollView>
</LinearLayout>
