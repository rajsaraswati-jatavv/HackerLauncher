<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="#1A1A2E"
    android:layout_margin="2dp">

    <!-- Process Name -->
    <TextView
        android:id="@+id/textViewProcessName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#00FF41"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1" />

    <!-- PID / UID Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/textViewPid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PID: 1234"
            android:textColor="#888888"
            android:fontFamily="monospace"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/textViewUid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="UID: 10045"
            android:textColor="#888888"
            android:fontFamily="monospace"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Memory / CPU / Importance Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/textViewMemory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="45.2 MB"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/textViewCpu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CPU: 2.3%"
            android:textColor="#FFFF00"
            android:fontFamily="monospace"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/textViewImportance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BG"
            android:textColor="#FF4444"
            android:fontFamily="monospace"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Kill / Blacklist Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="end">

        <Button
            android:id="@+id/buttonBlacklist"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="+ BL"
            android:textColor="#FFFF00"
            android:backgroundTint="#1A1A1A"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:minWidth="50dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/buttonKill"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="Kill"
            android:textColor="#000000"
            android:backgroundTint="#00FF41"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:minWidth="50dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />
    </LinearLayout>
</LinearLayout>
