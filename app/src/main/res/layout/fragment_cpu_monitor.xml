<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CPU MONITOR"
            android:textColor="#00FF00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <!-- CPU Usage & Cores Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/textViewCpuUsage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0%"
                android:textColor="#00FF00"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textViewCpuCores"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cores: --"
                android:textColor="#888888"
                android:textSize="14sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- CPU Frequency -->
        <TextView
            android:id="@+id/textViewCpuFreq"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Freq: -- MHz"
            android:textColor="#FFFF00"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- CPU Temperature -->
        <TextView
            android:id="@+id/textViewCpuTemp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Temp: -- °C"
            android:textColor="#FFFF00"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- CPU Governor -->
        <TextView
            android:id="@+id/textViewCpuGovernor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Governor: --"
            android:textColor="#888888"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <!-- CPU Graph View -->
        <FrameLayout
            android:id="@+id/cpuGraphContainer"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginBottom="8dp" />

        <!-- CPU Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBarCpu"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#00FF00"
            android:progressBackgroundTint="#1A1A1A"
            android:layout_marginBottom="12dp" />

        <!-- Kill High CPU Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonKillHighCpu"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Kill High CPU Processes"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="12sp"
            app:backgroundTint="#1B3A1B"
            app:strokeColor="#00FF00"
            android:layout_marginBottom="12dp" />

        <!-- CPU Processes Recycler -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewCpuProcesses"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#0A0A0A"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
