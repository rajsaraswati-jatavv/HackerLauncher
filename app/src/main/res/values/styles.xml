<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HackerLauncher" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">#FF00FF00</item>
        <item name="colorPrimaryDark">#FF005500</item>
        <item name="colorAccent">#FF00FF00</item>
        <item name="android:windowBackground">#FF000000</item>
        <item name="android:textColorPrimary">#FF00FF00</item>
        <item name="android:textColorSecondary">#FF00AA00</item>
        <item name="android:statusBarColor">#FF000000</item>
        <item name="android:navigationBarColor">#FF000000</item>
        <item name="android:fontFamily">monospace</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="HackerButton" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">#FF1A1A1A</item>
        <item name="android:textColor">#FF00FF00</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">11sp</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:layout_margin">2dp</item>
    </style>

    <style name="HackerButtonSmall" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">#FF1A1A1A</item>
        <item name="android:textColor">#FF00FF00</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">10sp</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:layout_margin">2dp</item>
    </style>
</resources>
